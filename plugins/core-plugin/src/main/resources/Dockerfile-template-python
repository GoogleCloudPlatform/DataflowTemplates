FROM ${basePythonContainerImage}

ARG WORKDIR=${workingDirectory}
RUN mkdir -p $WORKDIR
${filesToCopy}
${directoriesToCopy}
WORKDIR $WORKDIR

# Do NOT use ENV FLEX_TEMPLATE_PYTHON_REQUIREMENTS_FILE here. That env var triggers
# the Beam stager to run pip download --platform manylinux2014_x86_64 for every package,
# which is broken for packages that no longer publish manylinux2014 wheels (e.g. numpy 2.4+).
# See https://github.com/pypa/pip/issues/10760
# FLEX_TEMPLATE_PYTHON_SETUP_FILE (via setupFileEnv) IS needed to stage custom code to workers.
ENV FLEX_TEMPLATE_PYTHON_PY_FILE=main.py
${setupFileEnv}

RUN if ! [ -f ${requirementsFile} ] ; then >&2 echo "error: no ${requirementsFile} file found" && exit 1 ; fi

# Set up custom PyPi repository, if applicable
${airlockConfig}

RUN pip install -U --require-hashes -r ${requirementsFile}
${setupInstall}
RUN pip download --require-hashes --no-cache-dir --dest /tmp/dataflow-requirements-cache -r ${requirementsFile}

ENTRYPOINT ${entryPoint}
